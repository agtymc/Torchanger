<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.agty.torchanger.torchanger.TorchangerController" styleClass="app-root">
    <top>
        <VBox spacing="12.0">
            <padding>
                <Insets top="16.0" right="16.0" bottom="0.0" left="16.0"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label fx:id="titleLabel" styleClass="title-label"/>
                <HBox spacing="8.0" HBox.hgrow="ALWAYS"/>
                <Button fx:id="startAllButton" onAction="#onStartAllClick" styleClass="accent-button"/>
                <Button fx:id="stopAllButton" onAction="#onStopAllClick" styleClass="secondary-button"/>
                <Button fx:id="restartAllButton" onAction="#onRestartAllClick" styleClass="secondary-button"/>
                <Button fx:id="updateBridgesButton" onAction="#onUpdateBridgesClick" styleClass="secondary-button"/>
                <Button fx:id="settingsButton" onAction="#onSettingsClick" styleClass="secondary-button"/>
                <Button fx:id="exitButton" onAction="#onExitClick" styleClass="danger-button"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="10.0">
            <padding>
                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
            </padding>
            <TableView fx:id="methodsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="methodColumn" prefWidth="200.0"/>
                    <TableColumn fx:id="socksColumn" prefWidth="95.0"/>
                    <TableColumn fx:id="httpColumn" prefWidth="95.0"/>
                    <TableColumn fx:id="statusColumn" prefWidth="120.0"/>
                    <TableColumn fx:id="pingColumn" prefWidth="95.0"/>
                    <TableColumn fx:id="avgColumn" prefWidth="95.0"/>
                    <TableColumn fx:id="autoStartColumn" prefWidth="96.0"/>
                    <TableColumn fx:id="actionsColumn" prefWidth="112.0"/>
                </columns>
            </TableView>
            <Label fx:id="logsLabel" styleClass="section-label"/>
            <TabPane fx:id="logsTabPane" prefHeight="270.0" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"/>
            <TextArea fx:id="overallLogArea" managed="false" prefHeight="0.0" visible="false"/>
        </VBox>
    </center>
</BorderPane>
